{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/main/core/tauri-config-schema/schema.json",
  "productName": "EKO",
  "version": "1.2.6",
  "identifier": "com.eko.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "\u56fe\u7247\u53cd\u63a8\u5de5\u5177",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Alon9527/EKO_LocalAnalysis/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGRkI4NkJFQjRCQkY0NzEKUldSeDlMdTB2b2I3djdjQVh0QkovbkgzNmR6VnkyMDlDWjliUkU3ekpxeVdhd3NJcS9ScHVXODkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }

}
